{% extends 'expenses/partials/sidebar.html' %}
{% load static %}

{% block title %}Budget Management - BudgetWise{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="{% static 'css/modern-dashboard.css' %}">
<style>
.budget-overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
}

.budget-month-card {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: 20px;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--border);
    transition: all 0.2s;
}

.budget-month-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.budget-month-card.has-budget {
    border-left-color: var(--success);
}

.budget-month-card.over-budget {
    border-left-color: var(--danger);
}

.budget-month-card.no-budget {
    border-left-color: var(--warning);
}

.month-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}

.month-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
}

.budget-status {
    padding: 4px 12px;
    border-radius: var(--radius);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
}

.status-set {
    background: #d1fae5;
    color: #065f46;
}

.status-over {
    background: #fee2e2;
    color: #991b1b;
}

.status-none {
    background: #fef3c7;
    color: #92400e;
}

.budget-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
}

.budget-item {
    text-align: center;
}

.budget-label {
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 4px;
    text-transform: uppercase;
    font-weight: 600;
}

.budget-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
}

.budget-value.positive {
    color: var(--success);
}

.budget-value.negative {
    color: var(--danger);
}

.progress-bar {
    width: 100%;
    height: 8px;
    background: var(--bg-tertiary);
    border-radius: 4px;
    overflow: hidden;
    margin-top: 12px;
}

.progress-fill {
    height: 100%;
    transition: width 0.3s ease;
    border-radius: 4px;
}

.progress-success {
    background: var(--success);
}

.progress-warning {
    background: var(--warning);
}

.progress-danger {
    background: var(--danger);
}

.budget-form-section {
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: 24px;
    box-shadow: var(--shadow);
    margin-bottom: 32px;
}

.form-section-title {
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 16px;
    align-items: end;
}

.form-group {
    display: flex;
    flex-direction: column;
}

.form-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.form-input {
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 14px;
    transition: all 0.2s;
}

.form-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
}

.btn-primary {
    padding: 12px 24px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: var(--radius);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
}

@media (max-width: 768px) {
    .form-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }
    
    .budget-details {
        grid-template-columns: 1fr;
        gap: 12px;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="main-content">
    <div class="top-bar">
        <div class="top-bar-left">
            <h1>Budget Management</h1>
            <p class="subtitle">Set and manage budgets for different months</p>
        </div>
        <div class="top-bar-right">
            <a href="{% url 'expenses:dashboard' %}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Messages -->
    {% if messages %}
    <div class="messages-container">
        {% for message in messages %}
        <div class="alert alert-{{ message.tags }}">
            <span>{{ message }}</span>
            <button class="alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <!-- Budget Form -->
    <div class="budget-form-section">
        <h2 class="form-section-title">Set Monthly Budget</h2>
        <form method="post">
            {% csrf_token %}
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="{{ budget_form.month.id_for_label }}">Month</label>
                    {{ budget_form.month }}
                </div>
                <div class="form-group">
                    <label class="form-label" for="{{ budget_form.amount.id_for_label }}">Budget Amount (₹)</label>
                    {{ budget_form.amount }}
                </div>
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i> Set Budget
                </button>
            </div>
        </form>
    </div>

    <!-- Budget Overview -->
    <div class="budget-overview-section">
        <h2 class="form-section-title">Budget Overview (Last 12 Months)</h2>
        <div class="budget-overview-grid">
            {% for month_data in budget_overview %}
            <div class="budget-month-card {% if month_data.has_budget %}has-budget{% elif month_data.is_over_budget %}over-budget{% else %}no-budget{% endif %}">
                <div class="month-header">
                    <h3 class="month-title">{{ month_data.month_display }}</h3>
                    <div class="budget-status {% if month_data.has_budget %}status-set{% elif month_data.is_over_budget %}status-over{% else %}status-none{% endif %}">
                        {% if month_data.has_budget %}
                            {% if month_data.is_over_budget %}Over Budget{% else %}Budget Set{% endif %}
                        {% else %}
                            No Budget
                        {% endif %}
                    </div>
                </div>
                
                <div class="budget-details">
                    <div class="budget-item">
                        <div class="budget-label">Budget</div>
                        <div class="budget-value">₹{{ month_data.budget_amount|floatformat:0 }}</div>
                    </div>
                    <div class="budget-item">
                        <div class="budget-label">Spent</div>
                        <div class="budget-value">₹{{ month_data.expenses|floatformat:0 }}</div>
                    </div>
                    <div class="budget-item">
                        <div class="budget-label">Savings</div>
                        <div class="budget-value {% if month_data.savings >= 0 %}positive{% else %}negative{% endif %}">
                            ₹{{ month_data.savings|floatformat:0 }}
                        </div>
                    </div>
                    <div class="budget-item">
                        <div class="budget-label">Usage</div>
                        <div class="budget-value">{{ month_data.usage_percentage|floatformat:1 }}%</div>
                    </div>
                </div>
                
                {% if month_data.has_budget %}
                <div class="progress-bar">
                    <div class="progress-fill {% if month_data.usage_percentage <= 75 %}progress-success{% elif month_data.usage_percentage <= 100 %}progress-warning{% else %}progress-danger{% endif %}" 
                         style="width: {{ month_data.usage_percentage|floatformat:0 }}%"></div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// Auto-hide messages after 5 seconds
setTimeout(function() {
    const messages = document.querySelectorAll('.alert');
    messages.forEach(function(message) {
        message.style.opacity = '0';
        setTimeout(function() {
            message.style.display = 'none';
        }, 300);
    });
}, 5000);
</script>
{% endblock %}